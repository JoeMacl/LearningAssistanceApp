<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvQuizTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Generated Task 1"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvQuizDescription"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Answer the following questions."
            android:textSize="16sp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/tvQuestion1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Question 1"
            android:textSize="18sp"
            android:layout_marginTop="20dp" />

        <RadioGroup
            android:id="@+id/radioGroupQuestion1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp">

            <RadioButton
                android:id="@+id/rbQ1Option1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Option 1" />

            <RadioButton
                android:id="@+id/rbQ1Option2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Option 2" />

            <RadioButton
                android:id="@+id/rbQ1Option3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Option 3" />
        </RadioGroup>

        <TextView
            android:id="@+id/tvQuestion2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Question 2"
            android:textSize="18sp"
            android:layout_marginTop="28dp" />

        <RadioGroup
            android:id="@+id/radioGroupQuestion2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp">

            <RadioButton
                android:id="@+id/rbQ2Option1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Option 1" />

            <RadioButton
                android:id="@+id/rbQ2Option2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Option 2" />

            <RadioButton
                android:id="@+id/rbQ2Option3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Option 3" />
        </RadioGroup>

        <Button
            android:id="@+id/btnGenerateHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Press Generate Hint to receive study support."
            android:layout_marginTop="24dp" />

        <TextView
            android:id="@+id/tvPromptLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Prompt will appear here."
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginTop="16dp" />

        <TextView
            android:id="@+id/tvPromptText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No prompt yet"
            android:textSize="15sp"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/tvHintLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hint Response:"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginTop="16dp" />

        <TextView
            android:id="@+id/tvHintResponse"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No hint generated yet"
            android:textSize="15sp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="24dp" />

        <Button
            android:id="@+id/btnSubmitQuiz"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Submit"
            android:layout_marginTop="32dp" />

    </LinearLayout>
</ScrollView>