<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your Results"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginBottom="20dp" />

        <TextView
            android:id="@+id/tvScore"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Score: 0/2"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="20dp" />

        <TextView
            android:id="@+id/tvSummaryFeedback"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Summary feedback"
            android:textSize="16sp"
            android:layout_marginBottom="20dp" />

        <TextView
            android:id="@+id/tvResultMessage1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Question 1 result"
            android:textSize="16sp"
            android:layout_marginBottom="20dp" />

        <TextView
            android:id="@+id/tvResultMessage2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Question 2 result"
            android:textSize="16sp"
            android:layout_marginBottom="24dp" />

        <Button
            android:id="@+id/btnExplainAnswers"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Explain Answers"
            android:layout_marginTop="12dp" />

        <TextView
            android:id="@+id/tvExplainPromptLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Prompt:"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginTop="16dp" />

        <TextView
            android:id="@+id/tvExplainPrompt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Prompt will appear here."
            android:textSize="15sp"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/tvExplainResponseLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AI Explanation:"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginTop="16dp" />

        <TextView
            android:id="@+id/tvExplainResponse"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Press Explain Answers to learn more."
            android:textSize="15sp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="20dp" />

        <Button
            android:id="@+id/btnContinue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Back to Dashboard" />

    </LinearLayout>
</ScrollView>